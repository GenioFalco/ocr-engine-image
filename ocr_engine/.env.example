DATABASE_URL=postgresql://user:password@db:5432/ocr_db
GIGACHAT_CREDENTIALS=your_gigachat_credentials
LLM_PROVIDER=gigachat
LOG_LEVEL=INFO

# AD FS / OpenID Connect (заполнить после регистрации приложения у IT Askona)
ADFS_ENABLED=false
ADFS_CLIENT_ID=
ADFS_CLIENT_SECRET=
ADFS_TENANT_URL=https://fs.askona.ru/adfs
ADFS_REDIRECT_URI=https://your-domain/auth/adfs/callback

# URL фронтенда — куда редиректить после входа через AD FS
FRONTEND_URL=http://localhost:5173
